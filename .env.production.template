# === AdVantage AI - Production Environment ===
# Copy this to .env.production and fill in real values
# In GCP, these should be stored in Secret Manager instead

# Database (Cloud SQL PostgreSQL)
DATABASE_URL="postgresql://advantage:STRONG_PASSWORD@/advantage_db?host=/cloudsql/PROJECT_ID:asia-south1:advantage-db"

# Redis (optional; leave empty to run without cache and avoid Memorystore cost)
REDIS_URL=""

# JWT Secrets (generate with: openssl rand -base64 48)
JWT_SECRET="GENERATE_A_STRONG_SECRET_HERE"
JWT_REFRESH_SECRET="GENERATE_ANOTHER_STRONG_SECRET_HERE"

# Server
PORT=5000
NODE_ENV=production
CORS_ORIGINS="https://your-web-service-url-or-domain"

# Frontend URL (Cloud Run web service URL)
NEXT_PUBLIC_API_URL="https://advantage-backend-XXXXX-el.a.run.app"

# API Keys
# Build-time/public for the web image:
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
# Runtime/private for backend PDF map generation:
GOOGLE_MAPS_API_KEY=""

# Store backend secrets in Secret Manager:
ANTHROPIC_API_KEY=""

# GCP Storage (replaces AWS S3)
# GCS_BUCKET="advantage-uploads"
# GCS_PROJECT_ID="your-project-id"
